services:
  postgres:
    image: ${DOCKER_IMAGE_PREFIX}/${DOCKER_DB_IMAGE}:${DOCKER_POSTGRESQL_VERSION}
    container_name: ai_qa_postgres
    restart: unless-stopped
    ports:
      - "127.0.0.1:${DATABASE_PORT:-5432}:5432"
    environment:
      POSTGRES_DB: ${DATABASE_NAME}
      POSTGRES_USER: ${DATABASE_USER}
      POSTGRES_PASSWORD: ${DATABASE_PASSWORD}
    volumes:
      - postgres_data:/var/lib/postgresql
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DATABASE_USER} -d ${DATABASE_NAME}"]
      interval: 10s
      timeout: 5s
      retries: 5

  seaweedfs:
    image: ${DOCKER_IMAGE_PREFIX}/${DOCKER_FS_IMAGE}:${DOCKER_SEAWEEDFS_VERSION}
    container_name: ai_qa_seaweedfs
    restart: unless-stopped
    ports:
      - "127.0.0.1:8333:8333"
      - "127.0.0.1:9333:9333"
      - "127.0.0.1:8888:8888"
    volumes:
      - seaweedfs_data:/data
    command: server -s3 -dir=/data

  backend:
    image: ${DOCKER_IMAGE_PREFIX}/${DOCKER_BACKEND_IMAGE}:${DOCKER_IMAGE_VERSION:-latest}
    container_name: ai-qa-backend
    restart: unless-stopped
    ports:
      - "127.0.0.1:${SERVER_PORT:-8000}:8000"
    environment:
      # DB & Storage Connections (internal connections inside Docker)
      DATABASE_HOST: postgres
      DATABASE_PORT: 5432
      DATABASE_NAME: ${DATABASE_NAME}
      DATABASE_USER: ${DATABASE_USER}
      DATABASE_PASSWORD: ${DATABASE_PASSWORD}
      SEAWEEDFS_ENDPOINT: seaweedfs:8333
      SEAWEEDFS_ACCESS_KEY: ${SEAWEEDFS_ACCESS_KEY}
      SEAWEEDFS_SECRET_KEY: ${SEAWEEDFS_SECRET_KEY}
      
      # App metadata — surfaced as the OpenAPI version at /docs. Keep in sync with
      # the deployed image tag so the API self-reports the version it is running.
      DOCKER_IMAGE_VERSION: ${DOCKER_IMAGE_VERSION:-0.1.0}

      # Server & Session
      SERVER_HOST: 0.0.0.0
      SERVER_PORT: 8000
      SESSION_SECRET_KEY: ${SESSION_SECRET_KEY}
      SESSION_EXPIRE_HOURS: ${SESSION_EXPIRE_HOURS}
      SESSION_COOKIE_NAME: ${SESSION_COOKIE_NAME}
      SESSION_COOKIE_SECURE: ${SESSION_COOKIE_SECURE}
      SESSION_COOKIE_SAMESITE: ${SESSION_COOKIE_SAMESITE}
      
      # User Secret Encryption
      USER_SECRETS_ENCRYPTION_KEY: ${USER_SECRETS_ENCRYPTION_KEY}

      # External & AI API URLs
      ON_PREMISES_API_BASE_URL: ${ON_PREMISES_API_BASE_URL}
      BROWSER_USE_CLOUD_URL: ${BROWSER_USE_CLOUD_URL}
      CLAUDE_API_BASE_URL: ${CLAUDE_API_BASE_URL}
      GEMINI_API_BASE_URL: ${GEMINI_API_BASE_URL}
      OPENAI_API_BASE_URL: ${OPENAI_API_BASE_URL}

      # Claude SSO
      CLAUDE_SSO_AUTHORIZE_URL: ${CLAUDE_SSO_AUTHORIZE_URL}
      CLAUDE_SSO_TOKEN_URL: ${CLAUDE_SSO_TOKEN_URL}
      CLAUDE_SSO_CLIENT_ID: ${CLAUDE_SSO_CLIENT_ID}
      CLAUDE_SSO_REDIRECT_URI: ${CLAUDE_SSO_REDIRECT_URI}
      CLAUDE_SSO_ENTERPRISE_API_KEY: ${CLAUDE_SSO_ENTERPRISE_API_KEY}
      CLAUDE_SSO_ALLOWED_EMAIL_DOMAIN: ${CLAUDE_SSO_ALLOWED_EMAIL_DOMAIN}

      # Azure Entra ID SSO (user login — Epic 23). Leave the tenant/client/secret
      # triple EMPTY to use the built-in MOCK IdP; fill them for the real round-trip.
      # On air-gapped UAT, set HTTP(S)_PROXY/NO_PROXY OR paste the tenant JWKS into
      # AZURE_SSO_JWKS for zero-egress ID-token validation.
      AZURE_SSO_ENABLED: ${AZURE_SSO_ENABLED}
      AZURE_SSO_AUTO_PROVISION: ${AZURE_SSO_AUTO_PROVISION}
      AZURE_SSO_TENANT_ID: ${AZURE_SSO_TENANT_ID}
      AZURE_SSO_CLIENT_ID: ${AZURE_SSO_CLIENT_ID}
      AZURE_SSO_CLIENT_SECRET: ${AZURE_SSO_CLIENT_SECRET}
      AZURE_SSO_REDIRECT_URI: ${AZURE_SSO_REDIRECT_URI}
      AZURE_SSO_SCOPES: ${AZURE_SSO_SCOPES}
      AZURE_SSO_AUTHORITY: ${AZURE_SSO_AUTHORITY}
      AZURE_SSO_ALLOWED_EMAIL_DOMAIN: ${AZURE_SSO_ALLOWED_EMAIL_DOMAIN}
      AZURE_SSO_JWKS: ${AZURE_SSO_JWKS}

      # MCP & Browser
      MCP_SERVER_URL: ${MCP_SERVER_URL}
      MCP_TOOL_PREFIX: ${MCP_TOOL_PREFIX}
      MCP_TIMEOUT: ${MCP_TIMEOUT}
      MCP_MAX_RETRIES: ${MCP_MAX_RETRIES}
      MCP_RETRY_BACKOFF: ${MCP_RETRY_BACKOFF}
      BROWSER_TIMEOUT: ${BROWSER_TIMEOUT}

      # Execution capture (Jack run artifacts in the Reports panel). A Playwright
      # trace.zip is always captured; set true to ALSO record a .webm per test
      # (heavier on disk, playable inline — useful for headless UAT runs).
      EXECUTION_CAPTURE_VIDEOS: ${EXECUTION_CAPTURE_VIDEOS}

      # E2E in-app runner (admin "Run E2E Tests"). On a server keep
      # E2E_SERVER_MODE=1 → headless + sandbox disabled + TLS errors ignored.
      # BASE_URL must be the deployed HTTPS URL so Secure session cookies work
      # (a Secure cookie is never sent over plain HTTP, regardless of cert).
      # API_URL is the in-container backend used by global setup/teardown
      # (Bearer-token, server-to-server) — leave it as localhost:8000.
      E2E_SERVER_MODE: ${E2E_SERVER_MODE:-1}
      BASE_URL: ${BASE_URL}
      API_URL: ${API_URL:-http://localhost:8000}
      ADMIN_EMAIL: ${ADMIN_EMAIL}
      ADMIN_PASSWORD: ${ADMIN_PASSWORD}

      # For E2E and models sync
      TEST_BROWSER_USE_KEY: ${TEST_BROWSER_USE_KEY}
      TEST_CLAUDE_SSO_KEY: ${TEST_CLAUDE_SSO_KEY}
      TEST_CLAUDE_KEY: ${TEST_CLAUDE_KEY}
      TEST_GEMINI_KEY: ${TEST_GEMINI_KEY}
      TEST_OPENAI_KEY: ${TEST_OPENAI_KEY}
      TEST_ON_PREMISES_KEY: ${TEST_ON_PREMISES_KEY}
      LLM_STATS_API_KEY: ${LLM_STATS_API_KEY}
      LLM_STATS_API_BASE_URL: ${LLM_STATS_API_BASE_URL}      
    # Chromium needs more shared memory than the 64 MB Docker default.
    shm_size: "1gb"
    # If the backend container cannot resolve the public BASE_URL hostname,
    # map it to the Docker host gateway (routes back through the reverse proxy /
    # the published frontend port). Uncomment and set your hostname:
    # extra_hosts:
    #   - "ai-qa.ai-uat.corpdev.local:host-gateway"
    volumes:
      - workspace:/app/workspace
    depends_on:
      postgres:
        condition: service_healthy
      seaweedfs:
        condition: service_started

  frontend:
    image: ${DOCKER_IMAGE_PREFIX}/${DOCKER_FRONTEND_IMAGE}:${DOCKER_IMAGE_VERSION:-latest}
    container_name: ai-qa-frontend
    restart: unless-stopped
    ports:
      - "8080:80"
    depends_on:
      - backend

volumes:
  workspace:
  postgres_data:
  seaweedfs_data: