services:
  postgres:
    image: ${DOCKER_IMAGE_PREFIX}/ai-qa-db:${DOCKER_POSTGRESQL_VERSION}
    container_name: ai_qa_postgres
    restart: unless-stopped
    ports:
      - "127.0.0.1:${DATABASE_PORT:-5432}:5432"
    environment:
      POSTGRES_DB: ${DATABASE_NAME}
      POSTGRES_USER: ${DATABASE_USER}
      POSTGRES_PASSWORD: ${DATABASE_PASSWORD}
    volumes:
      - postgres_data:/var/lib/postgresql
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DATABASE_USER} -d ${DATABASE_NAME}"]
      interval: 10s
      timeout: 5s
      retries: 5

  seaweedfs:
    image: ${DOCKER_IMAGE_PREFIX}/ai-qa-fs:${DOCKER_SEAWEEDFS_VERSION}
    container_name: ai_qa_seaweedfs
    restart: unless-stopped
    ports:
      - "127.0.0.1:8333:8333"
      - "127.0.0.1:9333:9333"
    volumes:
      - seaweedfs_data:/data
    command: server -s3 -dir=/data

  backend:
    image: ${DOCKER_IMAGE_PREFIX}/${DOCKER_BACKEND_IMAGE}:${DOCKER_IMAGE_VERSION:-latest}
    container_name: ai_qa_backend
    restart: unless-stopped
    ports:
      - "127.0.0.1:${SERVER_PORT:-8000}:8000"
    environment:
      # DB & Storage Connections (internal connections inside Docker)
      DATABASE_HOST: postgres
      DATABASE_PORT: 5432
      DATABASE_NAME: ${DATABASE_NAME}
      DATABASE_USER: ${DATABASE_USER}
      DATABASE_PASSWORD: ${DATABASE_PASSWORD}
      SEAWEEDFS_ENDPOINT: seaweedfs:8333
      SEAWEEDFS_ACCESS_KEY: ${SEAWEEDFS_ACCESS_KEY}
      SEAWEEDFS_SECRET_KEY: ${SEAWEEDFS_SECRET_KEY}
      
      # Server & Session
      SERVER_HOST: 0.0.0.0
      SERVER_PORT: 8000
      SESSION_SECRET_KEY: ${SESSION_SECRET_KEY}
      SESSION_EXPIRE_HOURS: ${SESSION_EXPIRE_HOURS}
      SESSION_COOKIE_NAME: ${SESSION_COOKIE_NAME}
      SESSION_COOKIE_SECURE: ${SESSION_COOKIE_SECURE}
      SESSION_COOKIE_SAMESITE: ${SESSION_COOKIE_SAMESITE}
      
      # External & AI API URLs
      ON_PREMISES_API_BASE_URL: ${ON_PREMISES_API_BASE_URL}
      BROWSER_USE_CLOUD_URL: ${BROWSER_USE_CLOUD_URL}
      CLAUDE_API_BASE_URL: ${CLAUDE_API_BASE_URL}
      GEMINI_API_BASE_URL: ${GEMINI_API_BASE_URL}
      OPENAI_API_BASE_URL: ${OPENAI_API_BASE_URL}
      
      # MCP & Browser
      MCP_SERVER_URL: ${MCP_SERVER_URL}
      MCP_TOOL_PREFIX: ${MCP_TOOL_PREFIX}
      MCP_TIMEOUT: ${MCP_TIMEOUT}
      MCP_MAX_RETRIES: ${MCP_MAX_RETRIES}
      MCP_RETRY_BACKOFF: ${MCP_RETRY_BACKOFF}
      BROWSER_TIMEOUT: ${BROWSER_TIMEOUT}
    volumes:
      - workspace:/app/workspace
    depends_on:
      postgres:
        condition: service_healthy
      seaweedfs:
        condition: service_started

  frontend:
    image: ${DOCKER_IMAGE_PREFIX}/${DOCKER_FRONTEND_IMAGE}:${DOCKER_IMAGE_VERSION:-latest}
    container_name: ai_qa_frontend
    restart: unless-stopped
    ports:
      - "8080:80"
    depends_on:
      - backend

volumes:
  workspace:
  postgres_data:
  seaweedfs_data: