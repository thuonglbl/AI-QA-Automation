# src/ai_qa/agents/bob.py  lines ~1063-1190
    async def handle_approve(self, data: dict[str, Any] | None = None) -> None:
        """Override to handle paginated approval and parent confirmation."""
        if self.phase == "confirm_parent":
            # ... (11.2/11.3 confirm-parent + extraction branch — OUT OF SCOPE) ...
            return

        # Markdown Review Phase (Split Panel)
        if data and data.get("action") in ("approved", "not_requirement"):
            action = data.get("action")
            page_id = data.get("page_id")

            if not page_id:
                await self.send_message("No page_id provided for review action.", "error")
                return

            page = next((p for p in self.pages if p["page_id"] == page_id), None)
            if page is None:
                await self.send_message(f"Page '{page_id}' not found.", "error")
                return

            # Keep the index pointed at the acted page (the reject path reuses it)
            self.current_page_index = self.pages.index(page)

            if action == "approved":
                updated_markdown = data.get("markdown")
                if not updated_markdown:
                    await self.send_message("Markdown cannot be empty.", "error")
                    return

                page["requirement_md"] = updated_markdown
                if self.project_context is None:
                    raise ValueError("BobAgent requires an active project context.")
                adapter = PipelineArtifactAdapter(self.project_context)

                source_type = str(page.get("source_type") or "confluence")
                source_url = str(page.get("source_url") or "")
                quality_issues = page.get("quality_issues") or []

                try:
                    adapter.save_requirement(
                        page_id=page["page_id"],
                        markdown=updated_markdown,
                        source_type=source_type,
                        source_url=source_url,
                        warnings=quality_issues,
                    )
                    # D8 (11.8): delete the pre-approval draft (advisory — never blocks approval).
                    adapter.delete_draft_requirement(page["page_id"])
                    adapter.save_metadata(
                        f"{page['page_id']}/requirement.metadata.json",
                        {
                            "source_url": source_url,
                            "extracted_at": datetime.now(UTC).isoformat(),
                            "source_type": source_type,
                            "quality_warnings_acknowledged": bool(quality_issues),
                            "acknowledged_quality_issues": quality_issues,
                            "acknowledged_at": datetime.now(UTC).isoformat(),
                            "artifact_kind": "requirements",
                        },
                    )
                    self.output_files_saved += 1
                except Exception as exc:
                    logger.error("Bob failed to save requirement: %s", exc, exc_info=True)
                    await self.send_message(
                        content=self._format_error_message(
                            [
                                "Failed to save the approved requirement to the project artifact store.",
                                f"Reason: {type(exc).__name__}.",
                                "Please approve again to retry. No partial requirement was saved.",
                            ]
                        ),
                        message_type="error",
                    )
                    return  # do NOT resolve this page id; do NOT transition to DONE

            self._resolved_page_ids.add(page_id)

        # DONE only when every extracted page has been approved or skipped.
        if self.pages and len(self._resolved_page_ids) >= len(self.pages):
            await self.transition_to(AgentState.DONE)
            await self.send_message(
                f"Saved {self.output_files_saved} approved requirements. "
                "I'm handing off to Mary to create test cases.",
                "success",
            )
            return
        # Otherwise the frontend stays on the review payload and navigates locally.
```

Notes for reviewers on §4:
- `save_requirement` and `save_metadata` are TWO separate `save_artifact` calls.
  If the requirement saves (commits) but the side-car `save_metadata` raises, the
  `except` fires AFTER the requirement is already committed → requirement exists
  without its side-car, page stays un-resolved, re-approval creates a duplicate.
  The story DECLARES this acceptable (warnings column is the durable record).
- On the `not_requirement` action, the `if action == "approved":` block is skipped
  and control falls to `self._resolved_page_ids.add(page_id)` — i.e. a skip resolves
  the page with no save.
- `save_metadata` is NOT inside the `try`'s rollback scope of the requirement — it is
  a second artifact write. Consider whether a side-car-only failure should block resolution.

