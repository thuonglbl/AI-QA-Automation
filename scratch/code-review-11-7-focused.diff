```python
# src/ai_qa/artifacts/service.py  (the atomic write AC3 relies on; provenance kwargs added above)
    def save_artifact(self, *, project_id, owner_user_id, kind, name, content,
                       agent_run_id=None, thread_id=None,
                       source_type=None, source_url=None, warnings=None) -> Artifact:
        self._validate_kind(kind)
        clean_name = self._validate_name(name)
        self._validate_agent_run(project_id, agent_run_id)
        self._validate_thread(project_id, thread_id)
        content_bytes = _content_to_bytes(content)
        content_hash = hashlib.sha256(content_bytes).hexdigest()

        artifact = Artifact(project_id=project_id, agent_run_id=agent_run_id, thread_id=thread_id,
                            created_by_user_id=owner_user_id, updated_by_user_id=owner_user_id,
                            kind=kind, name=clean_name, storage_path="pending", current_version=1,
                            source_type=source_type, source_url=source_url, warnings=warnings)
        self.db.add(artifact)
        self.db.flush()

        storage_path = None
        try:
            storage_path = self.storage.write(project_id=project_id, artifact_id=artifact.id,
                                               version=1, kind=kind, name=clean_name, content=content)
            artifact.storage_path = storage_path
            artifact.versions.append(ArtifactVersion(version=1, content_hash=content_hash,
                                                      storage_path=storage_path,
                                                      created_by_user_id=owner_user_id))
            self.db.commit()
        except Exception:
            self.db.rollback()
            if storage_path is not None:
                self.storage.delete(storage_path)
            raise

        self.db.refresh(artifact)
        return artifact

    # --- delete_artifact: invoked by the D8 dedupe loop in save_requirement (§2). ---
    # NOTE: this COMMITS, and deletes storage objects, BEFORE any subsequent re-save runs.
    def delete_artifact(self, *, project_id, artifact_id) -> bool:
        artifact = self.db.execute(select(Artifact).options(selectinload(Artifact.versions))
            .where(Artifact.project_id == project_id, Artifact.id == artifact_id)).scalar_one_or_none()
        if artifact is None:
            return False
        for version in artifact.versions:          # best-effort storage delete (irreversible)
            if version.storage_path:
                self.storage.delete(version.storage_path)
        if artifact.storage_path:
            self.storage.delete(artifact.storage_path)
        self.db.delete(artifact)
        self.db.commit()                            # <-- COMMITS the deletion
        return True
