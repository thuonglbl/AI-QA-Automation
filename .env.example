# AI QA Automation - Example Environment Variables

# --- Database ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ai_qa_automation
DATABASE_USER=replace-with-local-database-user
DATABASE_PASSWORD=replace-with-local-dev-password

# --- S3 Compatible Storage ---
SEAWEEDFS_ENDPOINT=localhost:8333
SEAWEEDFS_ACCESS_KEY=replace-with-local-dev-access-key
SEAWEEDFS_SECRET_KEY=replace-with-local-dev-secret-key

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# --- Session Security (Story 11-1) ---
# IMPORTANT: Change this to a secure random string in production!
SESSION_SECRET_KEY=your-secure-secret-key-min-32-characters
SESSION_EXPIRE_HOURS=8
SESSION_COOKIE_NAME=aiqa_session
# Set to true in production with HTTPS
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax

# --- User Secret Encryption (Story 9.1) ---
# REQUIRED at startup. Fernet key used to encrypt per-user AI provider / MCP secrets.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Never commit a real key and never store it in the database.
USER_SECRETS_ENCRYPTION_KEY=replace-with-fernet-key

# --- External Service URLs ---
# API keys are user-specific and must be entered in the UI, not stored in .env.
BROWSER_USE_CLOUD_URL=https://api.browser-use.com/api/v2
CLAUDE_API_BASE_URL=https://api.anthropic.com
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
OPENAI_API_BASE_URL=https://api.openai.com
ON_PREMISES_API_BASE_URL=your-server-api-url

# --- Claude SSO (enterprise OAuth login) ---
# Empty CLAUDE_SSO_AUTHORIZE_URL = use the built-in mock IdP login page (dev/E2E).
# Set it (+ token URL / client id) to federate to the real company IdP.
CLAUDE_SSO_AUTHORIZE_URL=
CLAUDE_SSO_TOKEN_URL=
CLAUDE_SSO_CLIENT_ID=
CLAUDE_SSO_REDIRECT_URI=
# Server-side Claude Enterprise license key used for actual model calls after a
# successful SSO login (mock/demo mode). Set this to make the SSO pipeline work.
CLAUDE_SSO_ENTERPRISE_API_KEY=
CLAUDE_SSO_ALLOWED_EMAIL_DOMAIN=

# --- MCP Server Integration ---
MCP_SERVER_URL=your-mcp-server-url
MCP_TOOL_PREFIX=company_
MCP_TIMEOUT=30
MCP_MAX_RETRIES=3
MCP_RETRY_BACKOFF=1.0

# --- Browser Configuration ---
BROWSER_TIMEOUT=30

# --- Docker / Artifactory Deployment ---
DOCKER_IMAGE_PREFIX=your-docker-image-prefix
DOCKER_BACKEND_IMAGE=ai-qa-automation/backend
DOCKER_FRONTEND_IMAGE=ai-qa-automation/frontend
DOCKER_DB_IMAGE=ai-qa-automation/database
DOCKER_FS_IMAGE=ai-qa-automation/file-storage
DOCKER_IMAGE_VERSION=0.5.1
DOCKER_PYTHON_VERSION=3.14.6
DOCKER_NODE_VERSION=26.3.0
DOCKER_UV_VERSION=0.11.20
DOCKER_NGINX_VERSION=1.31.1
DOCKER_POSTGRESQL_VERSION=18.4
DOCKER_SEAWEEDFS_VERSION=4.33
# Optional for docker login automation.
# Prefer interactive docker login when possible.
ARTIFACTORY_USERNAME=your-username
ARTIFACTORY_PASSWORD=your-password

# Note: config.yaml is no longer supported. All configuration happens via environment variables or UI.

# --- Testing Environment ---
BASE_URL=http://localhost:5173 # replace with real URL when deploy server
API_URL=http://localhost:8000
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-local-admin-password

# E2E in-app runner (admin "Run E2E Tests" button).
#   Local dev: leave E2E_SERVER_MODE unset/0 → headed browser + slow motion.
#   Deployed server: set E2E_SERVER_MODE=1 → headless, Chromium sandbox disabled,
#   TLS errors ignored; and point BASE_URL at the deployed HTTPS URL (a Secure
#   session cookie is never sent over plain HTTP), e.g.:
#     E2E_SERVER_MODE=1
#     API_URL=http://localhost:8000
E2E_SERVER_MODE=0

# Server-side provider keys. Used by the E2E tests AND by the admin dashboard
# "Sync models and benchmarks" action to discover each provider's models (seed via
# API for E2E; never commit real values). A missing key just skips that provider.
TEST_BROWSER_USE_KEY=replace-with-real-browser-use-key
TEST_CLAUDE_SSO_EMAIL=replace-with-your-company-email
TEST_CLAUDE_SSO_PASSWORD=replace-with-your-password
TEST_CLAUDE_KEY=replace-with-real-claude-key
TEST_GEMINI_KEY=replace-with-real-gemini-key
TEST_OPENAI_KEY=replace-with-real-openai-key
TEST_ON_PREMISES_KEY=replace-with-real-on-premises-key

# llm-stats.com Data API — benchmark scores for the admin "Sync models and benchmarks"
# action. Free Bearer key (ze_…) with no usage limits; create one at
# https://llm-stats.com/developer. Leave empty to discover models without scoring them.
LLM_STATS_API_KEY=
LLM_STATS_API_BASE_URL=https://api.llm-stats.com/stats/v1
