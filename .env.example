# AI QA Automation - Example Environment Variables

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# --- Session Security (Story 11-1) ---
# IMPORTANT: Change this to a secure random string in production!
SESSION_SECRET_KEY=your-secure-secret-key-min-32-characters
SESSION_EXPIRE_HOURS=8
SESSION_COOKIE_NAME=aiqa_session
SESSION_COOKIE_SECURE=false  # Set to true in production with HTTPS
SESSION_COOKIE_SAMESITE=Lax

# --- MCP Server Integration ---
MCP_SERVER_URL=http://localhost:3000
MCP_SERVER_KEY=
MCP_TIMEOUT=30
MCP_MAX_RETRIES=3
MCP_RETRY_BACKOFF=1.0

# --- Browser Configuration ---
CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
BROWSER_TIMEOUT=30

# --- Script Generation (FR6-9, NFR14) ---
SCRIPT_GENERATION_MODEL=sonnet
SCRIPT_GENERATION_TEMPERATURE=0.0
SCRIPT_GENERATION_TIMEOUT=120
MAX_SCRIPT_LENGTH=10000
CONFIDENCE_THRESHOLD=0.7

# --- Vision-Assisted Locator Identification (FR5, NFR1) ---
VISION_ENABLED=true
VISION_MODEL=sonnet
VISION_TIMEOUT=60
VISION_SCREENSHOT_QUALITY=85
LOCATOR_VALIDATION_ENABLED=true
VISION_FALLBACK_ON_ERROR=true

# Note: config.yaml is no longer supported. All configuration happens via environment variables or UI.
