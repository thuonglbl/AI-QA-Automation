# AI QA Automation - Example Environment Variables

# --- Database ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ai_qa_automation
DATABASE_USER=postgres
DATABASE_PASSWORD=replace-with-local-dev-password

# --- S3 Compatible Storage ---
SEAWEEDFS_ENDPOINT=localhost:8333
SEAWEEDFS_ACCESS_KEY=replace-with-local-dev-access-key
SEAWEEDFS_SECRET_KEY=replace-with-local-dev-secret-key

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# --- Session Security (Story 11-1) ---
# IMPORTANT: Change this to a secure random string in production!
SESSION_SECRET_KEY=your-secure-secret-key-min-32-characters
SESSION_EXPIRE_HOURS=8
SESSION_COOKIE_NAME=aiqa_session
# Set to true in production with HTTPS
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax

# --- User Secret Encryption (Story 9.1) ---
# REQUIRED at startup. Fernet key used to encrypt per-user AI provider / MCP secrets.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Never commit a real key and never store it in the database.
USER_SECRETS_ENCRYPTION_KEY=replace-with-fernet-key

# --- External Service URLs ---
# API keys are user-specific and must be entered in the UI, not stored in .env.
BROWSER_USE_CLOUD_URL=https://api.browser-use.com/api/v2
CLAUDE_API_BASE_URL=https://api.anthropic.com
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
OPENAI_API_BASE_URL=https://api.openai.com
ON_PREMISES_API_BASE_URL=your-server-api-url

# --- MCP Server Integration ---
MCP_SERVER_URL=your-mcp-server-url
MCP_TOOL_PREFIX=company_
MCP_TIMEOUT=30
MCP_MAX_RETRIES=3
MCP_RETRY_BACKOFF=1.0

# --- Browser Configuration ---
BROWSER_TIMEOUT=30

# --- Docker / Artifactory Deployment ---
DOCKER_IMAGE_PREFIX=your-docker-image-prefix
DOCKER_BACKEND_IMAGE=ai-qa-backend
DOCKER_FRONTEND_IMAGE=ai-qa-frontend
DOCKER_IMAGE_VERSION=v0.2.4
DOCKER_PYTHON_VERSION=3.14.5
DOCKER_NODE_VERSION=26.1.0
DOCKER_UV_VERSION=0.11.13
DOCKER_NGINX_VERSION=1.27
DOCKER_POSTGRESQL_VERSION=18
DOCKER_SEAWEEDFS_VERSION=4.31
# Optional for docker login automation.
# Prefer interactive docker login when possible.
ARTIFACTORY_USERNAME=your-username
ARTIFACTORY_PASSWORD=your-password

# Note: config.yaml is no longer supported. All configuration happens via environment variables or UI.

# --- Testing Environment ---
TEST_ENV=local
BASE_URL=http://localhost:5173
API_URL=http://localhost:8000
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-local-admin-password

# Real per-user secrets used only by E2E tests (seed via API, never commit real values).
TEST_BROWSER_USE_KEY=replace-with-real-browser-use-key
TEST_CLAUDE_KEY=replace-with-real-claude-key
TEST_GEMINI_KEY=replace-with-real-gemini-key
TEST_OPENAI_KEY=replace-with-real-openai-key
TEST_ON_PREMISES_KEY=replace-with-real-on-premises-key
TEST_MCP_KEY=replace-with-real-mcp-key
